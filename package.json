{
  "name": "cypress-vite",
  "version": "1.10.0",
  "description": "Run Cypress specs using Vite",
  "author": "Mohammad Ataei",
  "license": "MIT",
  "keywords": [
    "cypress",
    "cypress-plugin",
    "cypress-preprocessor",
    "vite"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mammadataei/cypress-vite/"
  },
  "bugs": {
    "url": "https://github.com/mammadataei/cypress-vite/issues"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "example": "pnpm --filter example",
    "test": "pnpm --filter example test",
    "format": "prettier --write . && pnpm lint --fix",
    "lint": "eslint . ",
    "check": "tsc && pnpm lint && prettier --check .",
    "prepare": "husky install",
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": "eslint --fix",
    "*.{js,jsx,ts,tsx,md,html,css}": "prettier --write"
  },
  "peerDependencies": {
    "chokidar": "^2 || ^3 || ^4 || ^5",
    "debug": "^2 || ^3 || ^4",
    "vite": "^2.9 || ^3 || ^4 || ^5 || ^6 || ^7 || ^8"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/debug": "^4.1.13",
    "@types/node": "^24.12.4",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "chokidar": "^5.0.0",
    "cypress": "^15.15.0",
    "debug": "^4.4.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vite": "^8.0.12"
  },
  "packageManager": "pnpm@9.15.9"
}
