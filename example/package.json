{
  "name": "example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "cypress": "start-server-and-test dev http://localhost:5173 'cypress open'",
    "cypress-run-all": "pnpm cypress:run && pnpm cypress:run:prebuild && pnpm cypress:run:spec && pnpm cypress:run:prebuild:spec",
    "cypress:run": "cypress run",
    "cypress:run:prebuild": "cypress run --config-file cypress-prebuild.config.ts",
    "cypress:run:spec": "pnpm cypress:run --spec 'tests/App.e2e.ts'",
    "cypress:run:prebuild:spec": "pnpm cypress:run:prebuild --spec 'tests/App.e2e.ts'",
    "test": "start-server-and-test dev http://localhost:5173 cypress-run-all",
    "test:ci": "pnpm cypress-run-all",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-feather": "^2.0.10",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@ngneat/falso": "^8.0.2",
    "@testing-library/cypress": "^10.1.3",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "cypress": "^15.15.0",
    "cypress-vite": "workspace:latest",
    "postcss": "^8.5.14",
    "start-server-and-test": "^3.0.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
