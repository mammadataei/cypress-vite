{
  "name": "example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "cy:open": "start-server-and-test dev http://localhost:5173 'cypress open'",
    "cy:run": "cypress run",
    "cy:run:prebuild": "cypress run --config-file cypress-prebuild.config.ts",
    "cy:run:all": "pnpm cy:run && pnpm cy:run:prebuild",
    "test": "start-server-and-test dev http://localhost:5173 'cy:run:all'",
    "test:ci": "pnpm cy:run:all",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-feather": "^2.0.10",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@ngneat/falso": "^8.0.2",
    "@testing-library/cypress": "^10.1.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "cypress": "^15.17.0",
    "cypress-vite": "workspace:^",
    "postcss": "^8.5.15",
    "start-server-and-test": "^3.0.11",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
